import java.util.Scanner;
class Document {

    // StringBuffer object to store and modify text
    private StringBuffer textBuffer;

    // Constructor initializes an empty StringBuffer
    Document() {
        textBuffer = new StringBuffer();
    }

    // Adds the given text to the existing text
    void addText(String input) {
        textBuffer.append(input);
    }

    // Clears all text from the buffer
    void clearText() {
        textBuffer.setLength(0);
    }

    // Reverses the text and then reverses it again
    // (Final output remains unchanged)
    void reverseText() {
        textBuffer.reverse();
    }

    // Deletes text from start index to end index
    // and then attempts to delete the same range again
    void deletetext(int start, int end) {
        textBuffer.delete(start, end);
    }

    // Displays the current text
    void displayText() {
        System.out.println(textBuffer);
    }

    // Main method to test the Document class
    public static void main(String[] args) {
        Scanner sc=new Sacnner(System.in);
        // Create a Document object
        Document doc = new Document();

        // Add text to the document
        System.out.println("Adding Text: Hello");
        doc.addText(sc.nextLine());
        doc.displayText();

        // Reverse the text
        System.out.println("Reversing Text:");
        doc.reverseText();
        doc.displayText();

        // Clear the text
        System.out.println("Clearing Text:");
        doc.clearText();
        doc.displayText();
    }
}
